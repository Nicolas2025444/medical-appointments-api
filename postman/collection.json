{
  "info": {
    "name": "Citas Médicas API",
    "description": "Colección completa para el Sistema de Gestión de Citas Médicas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:3000/api" },
    { "key": "TOKEN",    "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Dr. Luis Torres\",\n  \"email\": \"luis@medical.com\",\n  \"password\": \"123456\",\n  \"rol\": \"medico\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('TOKEN', res.data.token);",
                  "  console.log('Token guardado:', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@medical.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Mi perfil",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "👥 Usuarios",
      "item": [
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/usuarios",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Obtener usuario #1",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/usuarios/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/usuarios",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"María López\",\n  \"email\": \"maria@email.com\",\n  \"password\": \"123456\",\n  \"rol\": \"paciente\"\n}"
            }
          }
        },
        {
          "name": "Actualizar usuario #2",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/usuarios/2",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"María López Actualizada\",\n  \"email\": \"maria@email.com\",\n  \"rol\": \"paciente\",\n  \"activo\": true\n}"
            }
          }
        },
        {
          "name": "Eliminar usuario #2",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/usuarios/2",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "🏥 Especialidades",
