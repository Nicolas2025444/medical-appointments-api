    },
    {
      "name": "📅 Citas",
      "item": [
        {
          "name": "Listar citas",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/citas",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Obtener cita #1",
          "request": {
