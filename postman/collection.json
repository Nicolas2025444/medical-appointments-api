            "url": "{{BASE_URL}}/citas/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Programar cita",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/citas",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paciente_id\": 1,\n  \"medico_id\": 1,\n  \"fecha_hora\": \"2025-03-20T10:00:00\",\n  \"motivo\": \"Control de presión arterial\",\n  \"notas\": \"Paciente hipertenso\"\n}"
            }
          }
        },
        {
          "name": "Actualizar cita #1",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/citas/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
