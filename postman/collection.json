              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha_nac\": \"1990-05-15\",\n  \"genero\": \"M\",\n  \"telefono\": \"0987654321\",\n  \"direccion\": \"Nueva dirección 456\"\n}"
